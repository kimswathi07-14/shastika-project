  "chat_type_message": "ಸಂದೇಶ ಬರೆಯಿರಿ...",
  "chat_initializing": "ಚಾಟ್ ಶುರುಗೊಳಿಸಲಾಗುತ್ತಿದೆ...",
  "ai_assistant_title": "ಶಾಸ್ತಿಕ ರಫತಿ ಸಹಾಯಕ",
  "ai_assistant_subtitle": "ನಿಮ್ಮ ಸ್ನೇಹಪೂರ್ಣ ರಫತಿ ಮಾರ್ಗದರ್ಶಕ 🌾",
  "ai_placeholder": "ರಫತಿ, ಉತ್ಪನ್ನಗಳು, ಪ್ಯಾಕೇಜಿಂಗ್ ಬಗ್ಗೆ ಕೇಳಿ... 😊",
  "ai_greeting": "ಹಾಯ! 👋😊 ನಾನು ಶಾಸ್ತಿಕ ರಫತಿ ಸಹಾಯಕ",
  "ai_help_text": "ನೀವು ಸಹಾಯಕ್ಕೆ ಸಂಪರ್ಕ ಮಾಡಬಹುದು:\n🌿 ಉತ್ಪನ್ನ ಮಾಹಿತಿ\n📦 ಪ್ಯಾಕೇಜಿಂಗ್ ವಿಧಾನಗಳು\n🚚 ರವಾನೆ ಮತ್ತು ಲಾಜಿಸ್ಟಿಕ್ಸ್\n📋 ರಫತಿ ಡಾಕುಮೆಂಟೇಶನ್\n💰 ಬೆಲೆ ಪ್ರಶ್ನೆಗಳು\n\nನಾನು ಈ ಹೆಚ್ಚನ್ನು ಹೇಗೆ ಸಹಾಯ ಮಾಡಬಹುದು? 🌾",
  "ai_export_info": "ಖಾತ್ರಿ! 😊 ಕೃಷಿ ರಫತಿಗಾಗಿ, ಎಲ್ಲಾ ಉತ್ಪನ್ನಗಳು ಅಂತರರಾಷ್ಟ್ರೀಯ ಫೈಟೋಸಾನಿಟರಿ ಮಾನದಂಡಗಳನ್ನು ಪೂರೈಸಬೇಕು.\n\nಗೊತ್ತುಪಡಿಸಿದ ಪ್ರಮಾಣಪತ್ರಗಳು:\n✅ FSSAI\n✅ APEDA ನೋಂದಣಿ\n✅ ಫೈಟೋಸಾನಿಟರಿ ಸರ್ಟಿಫಿಕೇಟ್\n✅ ಮೂಲ ಪ್ರಮಾಣಪತ್ರ\n\nನಿರ್ದಿಷ್ಟ ಉತ್ಪನ್ನದ ಬಗ್ಗೆ ಸಹಾಯ ಬೇಕೇ? ಕೇಳಿ! 🌿",
  "ai_quality_info": "ಖುಷಿ ಸಹಾಯ ಮಾಡಲು! 🌟 ನಮ್ಮ ಗುಣಮಾನದ ಮಾನದಂಡಗಳು ವಿಶ್ವ ಮಟ್ಟದಿಂದ:\n\n🔍 ಗ್ರೇಡ್ A ಆಯ್ಕೆ ಮತ್ತು ದರ್ಜೆಗತ\n❄️ ಶೀತಲ ಸರಪಳಿ ನಿರ್ವಾಹಣೆ\n📋 3-ಹಂತದ ಗುಣಮಾನ ಪರಿಶೋಧನೆ\n🏷️ ಆಮದುಕಾರ ದೇಶದ ಸಂವಿಧಾನಕ್ಕೆ ಸಮನ್ವಯ\n\nಪ್ರತಿಟಿ ಉತ್ಪನ್ನ ಕಠಿನ ಪರಿಶೋಧನೆಯ ಮೂಲಕ ಹೋಗುತ್ತದೆ! 💪",
  "ai_packaging_info": "ಚೆನ್ನಾಗಿರುವ ಪ್ರಶ್ನೆ! 📦 ನಾವು ರಫತಿ-ಗ್ರೇಡ್ ಪ್ಯಾಕೇಜಿಂಗ್ ಬಳಸುತ್ತೇವೆ:\n\n🍌 ಬಾಳೆಹಣ್ಣುಗಳು → ತರಂಗಾಯಿತ ಪೆಟ್ಟೆಗಳು ಪಾಲಿ ಲೈನರ್‌ಗಳೊಂದಿಗೆ\n🥥 ತೆಂಗಿನಕಾಯಿ → ಶ್ರಿಂಕ್-ಮುತ್ತಿಗೊಳಿಸಿದ ಪ್ಯಾಲೆಟ್‌ಗಳು & ಕಮ್ಮಟಾ ಚೀಲಗಳು\n🥬 ತರಕಾರಿಗಳು → ಬಿನ್ನೆಬೆಳಿತ ಮುದ್ರೆಗಳು ಮತ್ತು ವಿಧ್ವಸ್ತ ಪಾಲಿ ಸೀಕೆಲುಗಳು\n\nಎಲ್ಲಾ ಪ್ಯಾಕೇಜಿಂಗ್ ISPM-15 ಮಾನದಂಡಗಳನ್ನು ಪೂರೈಸುತ್ತದೆ. ✨",
  "ai_shipping_info": "ಖಾತ್ರಿ! 🚢✈️ ಎರಡು ರವಾನೆ ವಿಧಾನಗಳು:\n\n**ಸಮುದ್ರ ಮಾರ್ಗ** (15-30 ದಿನಗಳು) — ಬೃಹತ್ ಪರಿಮಾಣಕ್ಕೆ ವೆಚ್ಚ-ಪರಿಣಾಮಕಾರಿ\n**ವಿಮಾನ ಮಾರ್ಗ** (2-5 ದಿನಗಳು) — ಕೊಳೆತುಹೋಗುವ ಮೂಲಕ್ಕೆ ಸೂಕ್ತ\n\nನಾವು ಕಸ್ಟಮ್ಸ್ ಸರಿದಿಕ್ಕುಳು ಮತ್ತು ಡಾಕುಮೆಂಟೇಶನ್ ನಿರ್ವಹಿಸುತ್ತೇವೆ! 😊",
  "ai_thank_you": "ಧನ್ಯವಾದಗಳು! 😊🌟 ಯಾವಾಗ ಸಹಾಯ ಮಾಡಲು ಖುಷಿವಾಗಿದೆ!\n\nಒಳ್ಳೆಯ ದಿನವನ್ನು ಕಳೆದುಕೊಳ್ಳಿ! 🌾✨",
  "ai_contact_text": "ನಿಮ್ಮ ಪ್ರಶ್ನೆಗೆ ಧನ್ಯವಾದಗಳು! 😊\n\nನಿರ್ದಿಷ್ಟ ಪ್ರಶ್ನೆಗಳಿಗಾಗಿ, ನಿಮ್ಮು ಸಂಪರ್ಕ ಮಾಡಬಹುದು:\n📧 ಇಮೇಲ್: kim.swathi.07@gmail.com\n📱 WhatsApp: +91 96290 90961\n\nಅಥವಾ ನಮ್ಮ ಉತ್ಪನ್ನಗಳು, ಪ್ಯಾಕೇಜಿಂಗ್, ರವಾನೆ, ಅಥವಾ ರಫತಿ ಗುಣಮಾನ ಬಗ್ಗೆ ಕೇಳಿ! 🌾✨",
